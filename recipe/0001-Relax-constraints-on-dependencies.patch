+    "protobuf",
     "ptyprocess==0.7.0",
     "pyasn1==0.6.3",
     "pyasn1-modules==0.4.2",
@@ -100,7 +101,8 @@ dependencies = [
     "requests==2.33.1",
     "rich==15.0.0",
     "rpds-py==0.30.0",
-    "secretstorage==3.5.0 ; sys_platform == 'linux'",
