From fcdb62223f93209af3e219405a283a71f757a2c1 Mon Sep 17 00:00:00 2001
From: Christophe Haen <christophe.haen@cern.ch>
Date: Thu, 4 Jun 2026 15:47:28 +0200
Subject: [PATCH] Relax constraints on protobuff and secretstorage dependencies

---
 pyproject.toml | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index eb8b4ca..91d9d2f 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -78,7 +78,8 @@ dependencies = [
     "packaging==26.2",
     "pexpect==4.9.0",
     "platformdirs==4.9.6",
-    "protobuf==6.33.6",
+    # Needed until https://github.com/conda-forge/protobuf-feedstock/issues/274  is fixed
+    "protobuf",
     "ptyprocess==0.7.0",
     "pyasn1==0.6.3",
     "pyasn1-modules==0.4.2",
@@ -99,7 +100,8 @@ dependencies = [
     "requests==2.33.1",
     "rich==15.0.0",
     "rpds-py==0.30.0",
-    "secretstorage==3.5.0 ; sys_platform == 'linux'",
+    # Needed until https://github.com/conda-forge/secretstorage-feedstock/pull/27 is fixed
+    "secretstorage",
     "six==1.17.0",
     "smmap==5.0.3",
     "sounddevice==0.5.5",
-- 
2.54.0

